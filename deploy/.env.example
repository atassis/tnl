# Copy to deploy/.env and fill in. Consumed by the Caddyfile (and your compose).

# Base wildcard domain. tnl serves *.<this>; the control plane is tnl-api.<this>.
TNL_DOMAIN=t.example.com

# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# DNS provider module name for ACME DNS-01 — see https://github.com/caddy-dns .
# Changing this requires rebuilding the Caddy image (see Caddy.Dockerfile).
TNL_DNS_PROVIDER=cloudflare

# API token for that provider; needs DNS-edit permission on the zone above.
TNL_DNS_TOKEN=your-dns-api-token
