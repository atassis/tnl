# Caddy image with the caddy-dns/cloudflare plugin baked in.
#
# Why:
# - tnl needs a wildcard cert for *.t.example.com.
# - Let's Encrypt only issues wildcards via the ACME DNS-01 challenge.
# - DNS-01 requires Caddy to write a TXT record into the zone, which
#   needs the matching DNS provider plugin compiled into the binary.
#
# Drop this file at /opt/caddy/Dockerfile on the gateway, then change
# the existing compose service to `build: .` (or build the image and
# reference its tag). The cloudflare plugin reads CF_API_TOKEN from
# the container environment (see deploy/tnl.caddy.example).
#
# Tested locally with caddy v2.11.3, xcaddy from the upstream
# caddy:2-builder image, and module dns.providers.cloudflare.
#
# Pinned to the 2.x float tag rather than a hard minor (e.g. 2.8.4)
# because xcaddy resolves go.uber.org/zap fresh on every build, and
# old caddy minors reference symbols that were removed in newer zap
# (zapslog.HandlerOptions, dropped in zap >= ~1.27). Hard-pinning a
# minor here means the build will eventually rot the same way; the
# floating 2.x tag tracks an internally-consistent dependency set.

FROM caddy:2-builder AS builder
RUN xcaddy build \
    --with github.com/caddy-dns/cloudflare

FROM caddy:2-alpine
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
