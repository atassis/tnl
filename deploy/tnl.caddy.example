# Tunnel data plane.
# Caddy terminates TLS for *.t.example.com, then reverse-proxies to tnld over
# loopback HTTP/1.1 with Connection: close (v0.1.0-alpha simplification).
#
# In v0.1.0-beta this may switch to h2c for cleaner per-request framing.
*.t.example.com {
    tls {
        dns <provider> {env.YOUR_DNS_TOKEN}
    }
    reverse_proxy 127.0.0.1:7777 {
        flush_interval -1
        header_up Connection close
    }
}
